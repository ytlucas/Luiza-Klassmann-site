---
<section id="servicos" class="py-12 md:py-20 bg-[#FDFBF7]">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-8 md:mb-14">
      <span class="text-brand-terracotta text-[10px] font-bold uppercase tracking-[0.3em] mb-4 block">
        Nossas Especialidades
      </span>
      <h2 class="text-5xl md:text-6xl mb-6">
        Nossas <span class="text-brand-sage italic font-light">Especialidades</span>
      </h2>
      <p class="text-brand-ink/50 max-w-2xl mx-auto font-light text-lg">
        Da massoterapia ao diagnóstico postural — tratamentos personalizados para corpo, recuperação e bem-estar.
      </p>
    </div>

    <!-- ── DESKTOP: static grid 5×2 ── -->
    <div class="hidden md:grid grid-cols-5 gap-5">
      {services.map((service, i) => (
        <div class="svc-card group bg-white rounded-[32px] overflow-hidden shadow-sm hover:shadow-2xl transition-all duration-500 border border-brand-gold/5 flex flex-col" style={`--delay: ${i * 80}ms`}>
          <div class="h-56 overflow-hidden relative flex-shrink-0">
            <img src={service.image} alt={service.title} class={`w-full h-full object-cover transition-transform duration-700 group-hover:scale-110 ${service.imgPosition === 'bottom' ? 'object-bottom' : 'object-top'}`} referrerpolicy="no-referrer" loading="lazy" decoding="async" width="300" height="224" />
          </div>
          <div class="p-6 flex flex-col flex-1">
            <h3 class="text-xl mb-2 group-hover:text-brand-terracotta transition-colors">{service.title}</h3>
            <p class="text-brand-ink/50 text-sm leading-relaxed mb-5 font-light flex-1">{service.description}</p>
            <a href="#" data-service={service.title} class="whatsapp-service-btn inline-flex items-center justify-center w-full py-3 bg-white border-2 border-brand-terracotta text-brand-terracotta rounded-2xl text-[10px] font-bold uppercase tracking-widest hover:bg-brand-terracotta/10 transition-all mt-auto" aria-label={`Agendar ${service.title}`}>
              Agendar
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-1"><path d="m9 18 6-6-6-6"/></svg>
            </a>
          </div>
        </div>
      ))}
    </div>

    <!-- ── MOBILE: carousel 1 (serviços 1–3) ── -->
    <div class="md:hidden space-y-10">
      <div class="svc-carousel" data-mobile-carousel="1">
        <div class="svc-track overflow-hidden">
          <div class="svc-slides flex gap-6 transition-transform duration-500 ease-in-out">
            {services.slice(0, 3).map((service) => (
              <div class="svc-slide flex-none group bg-white rounded-[32px] overflow-hidden shadow-sm hover:shadow-2xl transition-all duration-500 border border-brand-gold/5">
                <div class="h-56 overflow-hidden relative">
                  <img src={service.image} alt={service.title} class="w-full h-full object-cover object-top transition-transform duration-700 group-hover:scale-110" referrerpolicy="no-referrer" loading="lazy" decoding="async" width="400" height="224" />
                </div>
                <div class="p-6">
                  <h3 class="text-xl mb-2 group-hover:text-brand-terracotta transition-colors">{service.title}</h3>
                  <p class="text-brand-ink/50 text-sm leading-relaxed mb-5 font-light">{service.description}</p>
                  <a href="#" data-service={service.title} class="whatsapp-service-btn inline-flex items-center justify-center w-full py-3 bg-white border-2 border-brand-terracotta text-brand-terracotta rounded-2xl text-[10px] font-bold uppercase tracking-widest hover:bg-brand-terracotta/10 transition-all" aria-label={`Agendar ${service.title}`}>
                    Agendar
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-1"><path d="m9 18 6-6-6-6"/></svg>
                  </a>
                </div>
              </div>
            ))}
          </div>
        </div>
        <button class="svc-prev absolute top-1/2 -translate-y-1/2 -left-4 z-10 w-10 h-10 rounded-full bg-white border border-brand-gold/20 shadow-md flex items-center justify-center text-brand-ink hover:bg-brand-gold hover:text-white transition-all" aria-label="Anterior">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        </button>
        <button class="svc-next absolute top-1/2 -translate-y-1/2 -right-4 z-10 w-10 h-10 rounded-full bg-white border border-brand-gold/20 shadow-md flex items-center justify-center text-brand-ink hover:bg-brand-gold hover:text-white transition-all" aria-label="Próximo">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </button>
        <div class="svc-dots flex justify-center gap-2 mt-6"></div>
      </div>

      <!-- ── MOBILE: carousel 2 (serviços 4–6) ── -->
      <div class="svc-carousel" data-mobile-carousel="2">
        <div class="svc-track overflow-hidden">
          <div class="svc-slides flex gap-6 transition-transform duration-500 ease-in-out">
            {services.slice(3, 6).map((service) => (
              <div class="svc-slide flex-none group bg-white rounded-[32px] overflow-hidden shadow-sm hover:shadow-2xl transition-all duration-500 border border-brand-gold/5">
                <div class="h-56 overflow-hidden relative">
                  <img src={service.image} alt={service.title} class="w-full h-full object-cover object-top transition-transform duration-700 group-hover:scale-110" referrerpolicy="no-referrer" loading="lazy" decoding="async" width="400" height="224" />
                </div>
                <div class="p-6">
                  <h3 class="text-xl mb-2 group-hover:text-brand-terracotta transition-colors">{service.title}</h3>
                  <p class="text-brand-ink/50 text-sm leading-relaxed mb-5 font-light">{service.description}</p>
                  <a href="#" data-service={service.title} class="whatsapp-service-btn inline-flex items-center justify-center w-full py-3 bg-white border-2 border-brand-terracotta text-brand-terracotta rounded-2xl text-[10px] font-bold uppercase tracking-widest hover:bg-brand-terracotta/10 transition-all" aria-label={`Agendar ${service.title}`}>
                    Agendar
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-1"><path d="m9 18 6-6-6-6"/></svg>
                  </a>
                </div>
              </div>
            ))}
          </div>
        </div>
        <button class="svc-prev absolute top-1/2 -translate-y-1/2 -left-4 z-10 w-10 h-10 rounded-full bg-white border border-brand-gold/20 shadow-md flex items-center justify-center text-brand-ink hover:bg-brand-gold hover:text-white transition-all" aria-label="Anterior">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        </button>
        <button class="svc-next absolute top-1/2 -translate-y-1/2 -right-4 z-10 w-10 h-10 rounded-full bg-white border border-brand-gold/20 shadow-md flex items-center justify-center text-brand-ink hover:bg-brand-gold hover:text-white transition-all" aria-label="Próximo">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </button>
        <div class="svc-dots flex justify-center gap-2 mt-6"></div>
      </div>

      <!-- ── MOBILE: carousel 3 (serviços 7–9) ── -->
      <div class="svc-carousel" data-mobile-carousel="3">
        <div class="svc-track overflow-hidden">
          <div class="svc-slides flex gap-6 transition-transform duration-500 ease-in-out">
            {services.slice(6).map((service) => (
              <div class="svc-slide flex-none group bg-white rounded-[32px] overflow-hidden shadow-sm hover:shadow-2xl transition-all duration-500 border border-brand-gold/5">
                <div class="h-56 overflow-hidden relative">
                  <img src={service.image} alt={service.title} class="w-full h-full object-cover object-top transition-transform duration-700 group-hover:scale-110" referrerpolicy="no-referrer" loading="lazy" decoding="async" width="400" height="224" />
                </div>
                <div class="p-6">
                  <h3 class="text-xl mb-2 group-hover:text-brand-terracotta transition-colors">{service.title}</h3>
                  <p class="text-brand-ink/50 text-sm leading-relaxed mb-5 font-light">{service.description}</p>
                  <a href="#" data-service={service.title} class="whatsapp-service-btn inline-flex items-center justify-center w-full py-3 bg-white border-2 border-brand-terracotta text-brand-terracotta rounded-2xl text-[10px] font-bold uppercase tracking-widest hover:bg-brand-terracotta/10 transition-all" aria-label={`Agendar ${service.title}`}>
                    Agendar
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-1"><path d="m9 18 6-6-6-6"/></svg>
                  </a>
                </div>
              </div>
            ))}
          </div>
        </div>
        <button class="svc-prev absolute top-1/2 -translate-y-1/2 -left-4 z-10 w-10 h-10 rounded-full bg-white border border-brand-gold/20 shadow-md flex items-center justify-center text-brand-ink hover:bg-brand-gold hover:text-white transition-all" aria-label="Anterior">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        </button>
        <button class="svc-next absolute top-1/2 -translate-y-1/2 -right-4 z-10 w-10 h-10 rounded-full bg-white border border-brand-gold/20 shadow-md flex items-center justify-center text-brand-ink hover:bg-brand-gold hover:text-white transition-all" aria-label="Próximo">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </button>
        <div class="svc-dots flex justify-center gap-2 mt-6"></div>
      </div>
    </div>
  </div>
</section>

<style>
  /* ── Desktop card: fade-up on scroll ── */
  .svc-card {
    opacity: 0;
    transform: translateY(40px) perspective(800px);
    transition:
      opacity 0.6s ease var(--delay, 0ms),
      transform 0.6s ease var(--delay, 0ms),
      box-shadow 0.5s ease;
    transform-style: preserve-3d;
    will-change: transform;
  }
  .svc-card.visible {
    opacity: 1;
    transform: translateY(0) perspective(800px);
  }
  /* Tilt resets smoothly on leave */
  .svc-card.tilt-reset {
    transition: transform 0.5s ease, box-shadow 0.5s ease, opacity 0.6s ease var(--delay,0ms) !important;
  }

  .svc-carousel {
    position: relative;
  }
</style>

<script>
  const GAP = 24;

  function initCarousel(carousel: HTMLElement) {
    const track    = carousel.querySelector<HTMLElement>('.svc-track')!;
    const slidesEl = carousel.querySelector<HTMLElement>('.svc-slides')!;
    const slides   = carousel.querySelectorAll<HTMLElement>('.svc-slide');
    const dotsEl   = carousel.querySelector<HTMLElement>('.svc-dots')!;
    const prevBtn  = carousel.querySelector<HTMLButtonElement>('.svc-prev')!;
    const nextBtn  = carousel.querySelector<HTMLButtonElement>('.svc-next')!;

    const total = slides.length;
    let cur = 0;

    function sw(): number {
      return track.offsetWidth;
    }

    function setSizes() {
      const w = sw();
      slides.forEach(s => { s.style.width = `${w}px`; });
    }

    function buildDots() {
      dotsEl.innerHTML = '';
      for (let i = 0; i < total; i++) {
        const d = document.createElement('button');
        d.setAttribute('aria-label', `Posição ${i + 1}`);
        d.addEventListener('click', () => goTo(i));
        dotsEl.appendChild(d);
      }
    }

    function updateDots() {
      dotsEl.querySelectorAll('button').forEach((d, i) => {
        const active = i === cur;
        d.className = `h-2 rounded-full transition-all duration-300 ${active ? 'bg-brand-gold w-5' : 'bg-brand-gold/30 w-2'}`;
      });
    }

    function goTo(idx: number) {
      cur = Math.max(0, Math.min(idx, total - 1));
      slidesEl.style.transform = `translateX(-${cur * (sw() + GAP)}px)`;
      updateDots();
    }

    function init() {
      setSizes();
      buildDots();
      cur = 0;
      goTo(0);
    }

    prevBtn?.addEventListener('click', () => goTo(cur - 1));
    nextBtn?.addEventListener('click', () => goTo(cur + 1));
    window.addEventListener('resize', init);

    // Swipe
    let startX = 0;
    track.addEventListener('touchstart', e => { startX = e.touches[0].clientX; }, { passive: true });
    track.addEventListener('touchend', e => {
      const diff = startX - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 40) goTo(cur + (diff > 0 ? 1 : -1));
    });

    init();
  }

  document.querySelectorAll<HTMLElement>('.svc-carousel').forEach(initCarousel);

  // Fade-up animation for desktop grid cards
  const svcCards = document.querySelectorAll<HTMLElement>('.svc-card');
  const cardObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        cardObserver.unobserve(entry.target); // animate once
      }
    });
  }, { threshold: 0.12 });
  svcCards.forEach(card => cardObserver.observe(card));

  // WhatsApp links
  const PHONE = '5551993975325';
  document.querySelectorAll<HTMLAnchorElement>('.whatsapp-service-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      const service = btn.getAttribute('data-service') ?? '';
      const message = encodeURIComponent(`Olá! Quero agendar: ${service}`);
      window.open(`https://wa.me/${PHONE}?text=${message}`, '_blank', 'noopener,noreferrer');
    });
  });

  // 3D tilt effect on desktop cards
  const MAX_TILT = 8; // degrees
  document.querySelectorAll<HTMLElement>('.svc-card').forEach(card => {
    card.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = card.getBoundingClientRect();
      const cx = rect.left + rect.width  / 2;
      const cy = rect.top  + rect.height / 2;
      const rx = ((e.clientY - cy) / (rect.height / 2)) * -MAX_TILT;
      const ry = ((e.clientX - cx) / (rect.width  / 2)) *  MAX_TILT;
      card.classList.remove('tilt-reset');
      card.style.transform = `translateY(0) perspective(800px) rotateX(${rx}deg) rotateY(${ry}deg) scale(1.02)`;
      card.style.boxShadow = `0 24px 60px rgba(0,0,0,0.14)`;
    });
    card.addEventListener('mouseleave', () => {
      card.classList.add('tilt-reset');
      card.style.transform = `translateY(0) perspective(800px) rotateX(0deg) rotateY(0deg) scale(1)`;
      card.style.boxShadow = '';
    });
  });
</script>
