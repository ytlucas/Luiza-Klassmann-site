---
const services = [
  {
    title: "Liberação Miofascial",
    image: "/drenagemLinfatica.avif",
    description:
      "Técnica manual que atua na fáscia. A técnica utiliza pressões e deslizamentos para restaurar a mobilidade, aliviar dor e melhorar a postura.",
    tag: "Terapia Manual",
    imgPosition: "bottom",
  },
  {
    title: "Drenagem Linfática",
    image: "/DrenagemLinfática.JPG",
    description:
      "Estimula o sistema linfático para reduzir edemas, eliminar toxinas e melhorar a circulação em todo o organismo.",
    tag: "Bem-estar",
    imgPosition: "center",
  },
  {
    title: "Massagem Relaxante",
    image: "/massagemRelaxante.avif",
    description:
      "Promove relaxamento profundo, alivia o estresse e restabelece o equilíbrio físico e mental com técnicas suaves e fluidas.",
    tag: "Massoterapia",
    imgPosition: "center",
  },
  {
    title: "Massagem Terapêutica",
    image:
      "https://biocap.com.br/wp-content/uploads/2023/11/foto_blog_Novembro_1024x641_01.png",
    description: "Técnica específica para alívio de dores e tensões.",
    tag: "Massoterapia",
    imgPosition: "top",
  },
  {
    title: "Massagem Detox",
    image: "/massagemDetox.avif",
    description:
      "Estimula a eliminação de toxinas, melhora a circulação e proporciona sensação de leveza e renovação para o corpo.",
    tag: "Massoterapia",
    imgPosition: "bottom",
  },
  {
    title: "Auriculoterapia",
    image: "/auriculoterapia.avif",
    description:
      "Técnica complementar que utiliza o pavilhão auricular como área reflexa do corpo e possibilita trabalhar diversas questões de saúde.",
    tag: "Terapia Integrativa",
    imgPosition: "top",
  },
  {
    title: "Diagnóstico Postural",
    image: "/resultado1.avif",
    description:
      "Avaliação estática e dinâmica da saúde física (postura e movimento). Permite identificar comprometimentos posturais e prescrever exercícios de forma personalizada.",
    tag: "Avaliação",
    imgPosition: "top",
  },
  {
    title: "Recovery",
    image: "/recovery.avif",
    description:
      "Protocolo de recuperação ativa para atletas e praticantes de atividade física, visando regeneração muscular e performance.",
    tag: "Performance",
    imgPosition: "top",
  },
  {
    title: "Treinamento Físico Personalizado",
    image: "/exerciciosTerapeutico.avif",
    description: "Da prescrição ao acompanhamento.",
    tag: "Saúde & Movimento",
    imgPosition: "bottom",
  },
  {
    title: "Taping",
    image: "/tapping.jpg",
    description:
      "Bandagens elásticas para auxiliar na recuperação de lesões, modulação da dor, pós-parto, etc.",
    tag: "Recuperação",
    imgPosition: "top",
  },
];
---

<section id="servicos" class="py-12 md:py-20 bg-[#FDFBF7]">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-8 md:mb-14">
      <h2 class="text-5xl md:text-6xl mb-6">
        <span class="text-brand-sage italic font-light">Especialidades</span>
      </h2>
      <p class="text-brand-ink/50 max-w-2xl mx-auto font-light text-lg">
        Da Massoterapia ao Diagnóstico Postural. Tratamentos Personalizados para
        o bem-estar.
      </p>
    </div>

    <!-- ── DESKTOP: static grid 5×2 ── -->
    <div class="hidden md:grid grid-cols-5 gap-5 mb-14">
      {
        services.map((service, i) => (
          <div
            class="svc-card group bg-brand-bg rounded-[32px] overflow-hidden shadow-sm hover:shadow-2xl transition-all duration-500 border border-brand-gold/5 flex flex-col"
            style={`--delay: ${i * 80}ms`}
          >
            <div class="h-56 overflow-hidden relative flex-shrink-0">
              <img
                src={service.image}
                alt={service.title}
                class={`w-full h-full object-cover transition-transform duration-700 group-hover:scale-110 ${service.imgPosition === "bottom" ? "object-bottom" : service.imgPosition === "center" ? "object-center" : "object-top"}`}
                referrerpolicy="no-referrer"
                loading="lazy"
                decoding="async"
                width="300"
                height="224"
              />
            </div>
            <div class="p-6 flex flex-col flex-1">
              <h3 class="text-xl mb-2 group-hover:text-brand-terracotta transition-colors">
                {service.title}
              </h3>
              <p class="text-brand-ink/50 text-sm leading-relaxed mb-5 font-light flex-1">
                {service.description}
              </p>
            </div>
          </div>
        ))
      }
    </div>

    <!-- ── MOBILE: carousel 1 (serviços 1–5) ── -->
    <div class="md:hidden space-y-10 mb-14">
      <div class="svc-carousel" data-mobile-carousel="1">
        <div class="svc-track overflow-hidden">
          <div
            class="svc-slides flex gap-6 transition-transform duration-500 ease-in-out"
          >
            {
              services.slice(0, 5).map((service) => (
                <div class="svc-slide flex-none group bg-brand-bg rounded-[32px] overflow-hidden shadow-sm hover:shadow-2xl transition-all duration-500 border border-brand-gold/5">
                  <div class="h-56 overflow-hidden relative">
                    <img
                      src={service.image}
                      alt={service.title}
                      class={`w-full h-full object-cover transition-transform duration-700 group-hover:scale-110 ${service.imgPosition === "bottom" ? "object-bottom" : service.imgPosition === "center" ? "object-center" : "object-top"}`}
                      referrerpolicy="no-referrer"
                      loading="lazy"
                      decoding="async"
                      width="400"
                      height="224"
                    />
                  </div>
                  <div class="p-6">
                    <h3 class="text-xl mb-2 group-hover:text-brand-terracotta transition-colors">
                      {service.title}
                    </h3>
                    <p class="text-brand-ink/50 text-sm leading-relaxed font-light">
                      {service.description}
                    </p>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
        <div class="svc-dots flex justify-center gap-2 mt-4"></div>
        <p class="text-center text-brand-ink/40 text-xs mt-2 tracking-wide">
          Arraste para o lado →
        </p>
      </div>

      <!-- ── MOBILE: carousel 2 (serviços 6–10) ── -->
      <div class="svc-carousel" data-mobile-carousel="2">
        <div class="svc-track overflow-hidden">
          <div
            class="svc-slides flex gap-6 transition-transform duration-500 ease-in-out"
          >
            {
              services.slice(5).map((service) => (
                <div class="svc-slide flex-none group bg-brand-bg rounded-[32px] overflow-hidden shadow-sm hover:shadow-2xl transition-all duration-500 border border-brand-gold/5">
                  <div class="h-56 overflow-hidden relative">
                    <img
                      src={service.image}
                      alt={service.title}
                      class={`w-full h-full object-cover transition-transform duration-700 group-hover:scale-110 ${service.imgPosition === "bottom" ? "object-bottom" : service.imgPosition === "center" ? "object-center" : "object-top"}`}
                      referrerpolicy="no-referrer"
                      loading="lazy"
                      decoding="async"
                      width="400"
                      height="224"
                    />
                  </div>
                  <div class="p-6">
                    <h3 class="text-xl mb-2 group-hover:text-brand-terracotta transition-colors">
                      {service.title}
                    </h3>
                    <p class="text-brand-ink/50 text-sm leading-relaxed font-light">
                      {service.description}
                    </p>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
        <div class="svc-dots flex justify-center gap-2 mt-4"></div>
        <p class="text-center text-brand-ink/40 text-xs mt-2 tracking-wide">
          Arraste para o lado →
        </p>
      </div>
    </div>

    <!-- MAIN BUTTON -->
    <div class="flex justify-center w-full mt-6">
      <a
        href="#"
        id="main-schedule-btn"
        class="inline-flex items-center justify-center px-10 py-5 bg-brand-terracotta text-white rounded-full font-bold text-[13px] tracking-[0.2em] uppercase hover:bg-brand-sage hover:-translate-y-1 transition-all shadow-xl hover:shadow-2xl"
      >
        AGENDAR SESSÃO
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="ml-2 group-hover:translate-x-1 transition-transform duration-300"
          ><path d="m9 18 6-6-6-6"></path></svg
        >
      </a>
    </div>
  </div>
</section>

<style>
  /* ── Desktop card: fade-up on scroll ── */
  .svc-card {
    opacity: 0;
    transform: translateY(40px) perspective(800px);
    transition:
      opacity 0.6s ease var(--delay, 0ms),
      transform 0.6s ease var(--delay, 0ms),
      box-shadow 0.5s ease;
    transform-style: preserve-3d;
    will-change: transform;
  }
  .svc-card.visible {
    opacity: 1;
    transform: translateY(0) perspective(800px);
  }
  /* Tilt resets smoothly on leave */
  .svc-card.tilt-reset {
    transition:
      transform 0.5s ease,
      box-shadow 0.5s ease,
      opacity 0.6s ease var(--delay, 0ms) !important;
  }

  .svc-carousel {
    position: relative;
  }
</style>

<script>
  const GAP = 24;

  function initCarousel(carousel: HTMLElement) {
    const track = carousel.querySelector<HTMLElement>(".svc-track")!;
    const slidesEl = carousel.querySelector<HTMLElement>(".svc-slides")!;
    const slides = carousel.querySelectorAll<HTMLElement>(".svc-slide");
    const dotsEl = carousel.querySelector<HTMLElement>(".svc-dots")!;

    const total = slides.length;
    let cur = 0;

    function sw(): number {
      return track.offsetWidth;
    }

    function setSizes() {
      const w = sw();
      slides.forEach((s) => {
        s.style.width = `${w}px`;
      });
    }

    function buildDots() {
      dotsEl.innerHTML = "";
      if (!dotsEl || total <= 1) return;
      for (let i = 0; i < total; i++) {
        const d = document.createElement("button");
        d.setAttribute("aria-label", `Posição ${i + 1}`);
        d.addEventListener("click", () => goTo(i));
        dotsEl.appendChild(d);
      }
    }

    function updateDots() {
      const buttons = dotsEl.querySelectorAll("button");
      if (!buttons.length) return;
      buttons.forEach((d, i) => {
        const active = i === cur;
        d.className = `h-2 rounded-full transition-all duration-300 ${active ? "bg-brand-gold w-5" : "bg-brand-gold/30 w-2"}`;
      });
    }

    function goTo(idx: number) {
      cur = Math.max(0, Math.min(idx, total - 1));
      slidesEl.style.transform = `translateX(-${cur * (sw() + GAP)}px)`;
      updateDots();
    }

    function init() {
      setSizes();
      buildDots();
      cur = 0;
      goTo(0);
    }

    window.addEventListener("resize", init);

    // Swipe
    let startX = 0;
    track.addEventListener(
      "touchstart",
      (e) => {
        startX = e.touches[0].clientX;
      },
      { passive: true },
    );
    track.addEventListener("touchend", (e) => {
      const diff = startX - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 40) goTo(cur + (diff > 0 ? 1 : -1));
    });

    init();
  }

  document.querySelectorAll<HTMLElement>(".svc-carousel").forEach(initCarousel);

  // Fade-up animation for desktop grid cards
  const svcCards = document.querySelectorAll<HTMLElement>(".svc-card");
  if (svcCards.length) {
    const cardObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("visible");
            cardObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.12 },
    );
    svcCards.forEach((card) => cardObserver.observe(card));
  }

  // WhatsApp link for main schedule button
  const PHONE = "5551993975325";
  const mainBtn = document.getElementById("main-schedule-btn");
  if (mainBtn) {
    mainBtn.addEventListener("click", (e) => {
      e.preventDefault();
      const message = encodeURIComponent(
        `Olá! Gostaria de agendar uma sessão.`,
      );
      window.open(
        `https://wa.me/${PHONE}?text=${message}`,
        "_blank",
        "noopener,noreferrer",
      );
    });
  }

  // 3D tilt effect on desktop cards
  const MAX_TILT = 8; // degrees
  document.querySelectorAll<HTMLElement>(".svc-card").forEach((card) => {
    card.addEventListener("mousemove", (e: MouseEvent) => {
      const rect = card.getBoundingClientRect();
      const cx = rect.left + rect.width / 2;
      const cy = rect.top + rect.height / 2;
      const rx = ((e.clientY - cy) / (rect.height / 2)) * -MAX_TILT;
      const ry = ((e.clientX - cx) / (rect.width / 2)) * MAX_TILT;
      card.classList.remove("tilt-reset");
      card.style.transform = `translateY(0) perspective(800px) rotateX(${rx}deg) rotateY(${ry}deg) scale(1.02)`;
      card.style.boxShadow = `0 24px 60px rgba(0,0,0,0.14)`;
    });
    card.addEventListener("mouseleave", () => {
      card.classList.add("tilt-reset");
      card.style.transform = `translateY(0) perspective(800px) rotateX(0deg) rotateY(0deg) scale(1)`;
      card.style.boxShadow = "";
    });
  });
</script>
