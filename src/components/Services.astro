---
const services = [
  {
    title: "Ventosaterapia",
    image: "/Ventosaterapia.jpg",
    description:
      "Técnica milenar que utiliza ventosas para estimular a circulação, aliviar tensões musculares e promover o equilíbrio energético do organismo.",
    tag: "Terapia Integrativa",
    imgPosition: "center",
  },
  {
    title: "Liberação Miofascial",
    image: "/drenagemLinfatica.avif",
    description:
      "Técnica manual que atua na fáscia. A técnica utiliza pressões e deslizamentos para restaurar a mobilidade, aliviar dor e melhorar a postura.",
    tag: "Terapia Manual",
    imgPosition: "bottom",
  },
  {
    title: "Drenagem Linfática",
    image: "/DrenagemLinfática.JPG",
    description:
      "Estimula o sistema linfático para reduzir edemas, eliminar toxinas e melhorar a circulação em todo o organismo.",
    tag: "Bem-estar",
    imgPosition: "center",
  },
  {
    title: "Massagem Relaxante",
    image: "/massagemRelaxante.avif",
    description:
      "Promove relaxamento profundo, alivia o estresse e restabelece o equilíbrio físico e mental com técnicas suaves e fluidas.",
    tag: "Massoterapia",
    imgPosition: "center",
  },
  {
    title: "Massagem Terapêutica",
    image:
      "https://biocap.com.br/wp-content/uploads/2023/11/foto_blog_Novembro_1024x641_01.png",
    description: "Técnica específica para alívio de dores e tensões.",
    tag: "Massoterapia",
    imgPosition: "top",
  },
  {
    title: "Massagem Detox",
    image: "/massagemDetox.avif",
    description:
      "Estimula a eliminação de toxinas, melhora a circulação e proporciona sensação de leveza e renovação para o corpo.",
    tag: "Massoterapia",
    imgPosition: "bottom",
  },
  {
    title: "Auriculoterapia",
    image: "/auriculoterapia.avif",
    description:
      "Técnica complementar que utiliza o pavilhão auricular como área reflexa do corpo e possibilita trabalhar diversas questões de saúde.",
    tag: "Terapia Integrativa",
    imgPosition: "top",
  },
  {
    title: "Diagnóstico Postural",
    image: "/resultado1.avif",
    description:
      "Avaliação estática e dinâmica da saúde física (postura e movimento). Permite identificar comprometimentos posturais e prescrever exercícios de forma personalizada.",
    tag: "Avaliação",
    imgPosition: "top",
  },
  {
    title: "Recovery",
    image: "/recovery.avif",
    description:
      "Protocolo de recuperação ativa para atletas e praticantes de atividade física, visando regeneração muscular e performance.",
    tag: "Performance",
    imgPosition: "top",
  },
  {
    title: "Treinamento Físico Personalizado",
    image: "/exerciciosTerapeutico.avif",
    description: "Da prescrição ao acompanhamento.",
    tag: "Saúde & Movimento",
    imgPosition: "bottom",
  },
  {
    title: "Taping",
    image: "/tapping.jpg",
    description:
      "Bandagens elásticas para auxiliar na recuperação de lesões, modulação da dor, pós-parto, etc.",
    tag: "Recuperação",
    imgPosition: "top",
  },
];
---

<section id="servicos" class="py-12 md:py-20 bg-[#FDFBF7]">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-8 md:mb-14">
      <h2 class="text-5xl md:text-6xl mb-6">
        <span class="text-brand-sage italic font-light">Especialidades</span>
      </h2>
      <p class="text-brand-ink/50 max-w-2xl mx-auto font-light text-lg">
        Da Massoterapia ao Diagnóstico Postural. Tratamentos Personalizados para
        o bem-estar.
      </p>
    </div>

    <!-- ── DESKTOP: carousel showing 5 cards at a time ── -->
    <div class="hidden md:block mb-14">
      <!--
        Outer wrapper: position:relative so absolute arrows are anchored here.
        px-12 gives 48px on each side — enough room for the 44px arrow buttons.
      -->
      <div class="relative px-12" id="desktop-svc-wrapper">
        <!-- Left arrow — sits in the left padding, never clipped -->
        <button
          id="desktop-svc-prev"
          aria-label="Anterior"
          class="absolute left-0 top-1/2 -translate-y-8 z-10 bg-white border border-brand-gold/20 shadow-lg rounded-full w-11 h-11 flex items-center justify-center text-brand-ink hover:text-brand-terracotta hover:border-brand-terracotta transition-all"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        </button>

        <!-- Right arrow -->
        <button
          id="desktop-svc-next"
          aria-label="Próximo"
          class="absolute right-0 top-1/2 -translate-y-8 z-10 bg-white border border-brand-gold/20 shadow-lg rounded-full w-11 h-11 flex items-center justify-center text-brand-ink hover:text-brand-terracotta hover:border-brand-terracotta transition-all"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </button>

        <!-- Clipping track — overflow:hidden clips sliding cards only -->
        <div class="overflow-hidden" id="desktop-svc-track">
          <div
            class="flex gap-5 transition-transform duration-500 ease-in-out"
            id="desktop-svc-slides"
          >
            {
              services.map((service, i) => (
                <div
                  class="desktop-svc-slide flex-none svc-card group bg-brand-bg rounded-[32px] overflow-hidden shadow-sm hover:shadow-2xl transition-all duration-500 border border-brand-gold/5 flex flex-col"
                  style={`--delay: ${i * 80}ms`}
                >
                  <div class="h-56 overflow-hidden relative flex-shrink-0">
                    <img
                      src={service.image}
                      alt={service.title}
                      class={`w-full h-full object-cover transition-transform duration-700 group-hover:scale-110 ${service.imgPosition === "bottom" ? "object-bottom" : service.imgPosition === "center" ? "object-center" : "object-top"}`}
                      referrerpolicy="no-referrer"
                      loading="lazy"
                      decoding="async"
                      width="300"
                      height="224"
                    />
                  </div>
                  <div class="p-6 flex flex-col flex-1">
                    <h3 class="text-xl mb-2 group-hover:text-brand-terracotta transition-colors">
                      {service.title}
                    </h3>
                    <p class="text-brand-ink/50 text-sm leading-relaxed mb-5 font-light flex-1">
                      {service.description}
                    </p>
                  </div>
                </div>
              ))
            }
          </div>
        </div>

        <!-- Dots -->
        <div id="desktop-svc-dots" class="flex justify-center gap-2 mt-6"></div>
      </div>
    </div>

    <!-- ── MOBILE: carousel 1 (serviços 1–6) ── -->
    <div class="md:hidden space-y-10 mb-14">
      <div class="svc-carousel" data-mobile-carousel="1">
        <div class="svc-track overflow-hidden">
          <div
            class="svc-slides flex gap-6 transition-transform duration-500 ease-in-out"
          >
            {
              services.slice(0, 6).map((service) => (
                <div class="svc-slide flex-none group bg-brand-bg rounded-[32px] overflow-hidden shadow-sm hover:shadow-2xl transition-all duration-500 border border-brand-gold/5">
                  <div class="h-56 overflow-hidden relative">
                    <img
                      src={service.image}
                      alt={service.title}
                      class={`w-full h-full object-cover transition-transform duration-700 group-hover:scale-110 ${service.imgPosition === "bottom" ? "object-bottom" : service.imgPosition === "center" ? "object-center" : "object-top"}`}
                      referrerpolicy="no-referrer"
                      loading="lazy"
                      decoding="async"
                      width="400"
                      height="224"
                    />
                  </div>
                  <div class="p-6">
                    <h3 class="text-xl mb-2 group-hover:text-brand-terracotta transition-colors">
                      {service.title}
                    </h3>
                    <p class="text-brand-ink/50 text-sm leading-relaxed font-light">
                      {service.description}
                    </p>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
        <div class="svc-dots flex justify-center gap-2 mt-4"></div>
        <p class="text-center text-brand-ink/40 text-xs mt-2 tracking-wide">
          Arraste para o lado →
        </p>
      </div>

      <!-- ── MOBILE: carousel 2 (serviços 7–11) ── -->
      <div class="svc-carousel" data-mobile-carousel="2">
        <div class="svc-track overflow-hidden">
          <div
            class="svc-slides flex gap-6 transition-transform duration-500 ease-in-out"
          >
            {
              services.slice(6).map((service) => (
                <div class="svc-slide flex-none group bg-brand-bg rounded-[32px] overflow-hidden shadow-sm hover:shadow-2xl transition-all duration-500 border border-brand-gold/5">
                  <div class="h-56 overflow-hidden relative">
                    <img
                      src={service.image}
                      alt={service.title}
                      class={`w-full h-full object-cover transition-transform duration-700 group-hover:scale-110 ${service.imgPosition === "bottom" ? "object-bottom" : service.imgPosition === "center" ? "object-center" : "object-top"}`}
                      referrerpolicy="no-referrer"
                      loading="lazy"
                      decoding="async"
                      width="400"
                      height="224"
                    />
                  </div>
                  <div class="p-6">
                    <h3 class="text-xl mb-2 group-hover:text-brand-terracotta transition-colors">
                      {service.title}
                    </h3>
                    <p class="text-brand-ink/50 text-sm leading-relaxed font-light">
                      {service.description}
                    </p>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
        <div class="svc-dots flex justify-center gap-2 mt-4"></div>
        <p class="text-center text-brand-ink/40 text-xs mt-2 tracking-wide">
          Arraste para o lado →
        </p>
      </div>
    </div>

    <!-- MAIN BUTTON -->
    <div class="flex justify-center w-full mt-6">
      <a
        href="#"
        id="main-schedule-btn"
        class="inline-flex items-center justify-center px-10 py-5 bg-brand-terracotta text-white rounded-full font-bold text-[13px] tracking-[0.2em] uppercase hover:bg-brand-sage hover:-translate-y-1 transition-all shadow-xl hover:shadow-2xl"
      >
        AGENDAR SESSÃO
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="ml-2 group-hover:translate-x-1 transition-transform duration-300"
          ><path d="m9 18 6-6-6-6"></path></svg
        >
      </a>
    </div>
  </div>
</section>

<style>
  /* ── Desktop card: fade-up on scroll ── */
  .svc-card {
    opacity: 0;
    transform: translateY(40px) perspective(800px);
    transition:
      opacity 0.6s ease var(--delay, 0ms),
      transform 0.6s ease var(--delay, 0ms),
      box-shadow 0.5s ease;
    transform-style: preserve-3d;
    will-change: transform;
  }
  .svc-card.visible {
    opacity: 1;
    transform: translateY(0) perspective(800px);
  }
  .svc-card.tilt-reset {
    transition:
      transform 0.5s ease,
      box-shadow 0.5s ease,
      opacity 0.6s ease var(--delay, 0ms) !important;
  }

  .svc-carousel {
    position: relative;
  }
</style>

<script>
  /* ─────────────────────────────────────────
     DESKTOP CAROUSEL  (5 visible cards)
  ───────────────────────────────────────── */
  const DESK_GAP = 20;   // gap-5 = 1.25rem = 20px
  const DESK_VIS = 5;    // cards visible at once

  function initDesktopCarousel() {
    const track  = document.getElementById("desktop-svc-track");
    const slides = document.getElementById("desktop-svc-slides");
    const dotsEl = document.getElementById("desktop-svc-dots");
    const prevBtn = document.getElementById("desktop-svc-prev");
    const nextBtn = document.getElementById("desktop-svc-next");
    if (!track || !slides || !dotsEl || !prevBtn || !nextBtn) return;

    const cards = slides.querySelectorAll<HTMLElement>(".desktop-svc-slide");
    const total = cards.length;
    const maxIdx = total - DESK_VIS;   // last valid offset index
    let cur = 0;

    function cardW(): number {
      return (track.offsetWidth - DESK_GAP * (DESK_VIS - 1)) / DESK_VIS;
    }

    function setSizes() {
      const cw = cardW();
      cards.forEach((c) => {
        c.style.width = `${cw}px`;
        c.style.flexShrink = "0";
      });
    }

    function buildDots() {
      dotsEl.innerHTML = "";
      const pages = maxIdx + 1;
      if (pages <= 1) return;
      for (let i = 0; i < pages; i++) {
        const btn = document.createElement("button");
        btn.setAttribute("aria-label", `Posição ${i + 1}`);
        btn.addEventListener("click", () => goTo(i));
        dotsEl.appendChild(btn);
      }
    }

    function updateDots() {
      dotsEl.querySelectorAll("button").forEach((d, i) => {
        d.className = `h-2 rounded-full transition-all duration-300 ${
          i === cur ? "bg-brand-gold w-5" : "bg-brand-gold/30 w-2"
        }`;
      });
    }

    function updateArrows() {
      (prevBtn as HTMLButtonElement).style.opacity = cur === 0 ? "0.35" : "1";
      (prevBtn as HTMLButtonElement).style.pointerEvents = cur === 0 ? "none" : "auto";
      (nextBtn as HTMLButtonElement).style.opacity = cur >= maxIdx ? "0.35" : "1";
      (nextBtn as HTMLButtonElement).style.pointerEvents = cur >= maxIdx ? "none" : "auto";
    }

    function goTo(idx: number) {
      cur = Math.max(0, Math.min(idx, maxIdx));
      const offset = cur * (cardW() + DESK_GAP);
      slides.style.transform = `translateX(-${offset}px)`;
      updateDots();
      updateArrows();
    }

    function init() {
      setSizes();
      buildDots();
      goTo(0);
    }

    prevBtn.addEventListener("click", () => goTo(cur - 1));
    nextBtn.addEventListener("click", () => goTo(cur + 1));
    window.addEventListener("resize", init);
    init();
  }

  initDesktopCarousel();

  /* ─────────────────────────────────────────
     MOBILE CAROUSELS
  ───────────────────────────────────────── */
  const MOB_GAP = 24;

  function initCarousel(carousel: HTMLElement) {
    const track    = carousel.querySelector<HTMLElement>(".svc-track")!;
    const slidesEl = carousel.querySelector<HTMLElement>(".svc-slides")!;
    const slides   = carousel.querySelectorAll<HTMLElement>(".svc-slide");
    const dotsEl   = carousel.querySelector<HTMLElement>(".svc-dots")!;
    const total    = slides.length;
    let cur        = 0;

    function sw() { return track.offsetWidth; }

    function setSizes() {
      slides.forEach((s) => { s.style.width = `${sw()}px`; });
    }

    function buildDots() {
      dotsEl.innerHTML = "";
      if (total <= 1) return;
      for (let i = 0; i < total; i++) {
        const d = document.createElement("button");
        d.setAttribute("aria-label", `Posição ${i + 1}`);
        d.addEventListener("click", () => goTo(i));
        dotsEl.appendChild(d);
      }
    }

    function updateDots() {
      dotsEl.querySelectorAll("button").forEach((d, i) => {
        d.className = `h-2 rounded-full transition-all duration-300 ${
          i === cur ? "bg-brand-gold w-5" : "bg-brand-gold/30 w-2"
        }`;
      });
    }

    function goTo(idx: number) {
      cur = Math.max(0, Math.min(idx, total - 1));
      slidesEl.style.transform = `translateX(-${cur * (sw() + MOB_GAP)}px)`;
      updateDots();
    }

    function init() { setSizes(); buildDots(); goTo(0); }

    window.addEventListener("resize", init);

    let startX = 0;
    track.addEventListener("touchstart", (e) => { startX = e.touches[0].clientX; }, { passive: true });
    track.addEventListener("touchend",   (e) => {
      const diff = startX - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 40) goTo(cur + (diff > 0 ? 1 : -1));
    });

    init();
  }

  document.querySelectorAll<HTMLElement>(".svc-carousel").forEach(initCarousel);

  /* ── Fade-up animation for desktop cards ── */
  const svcCards = document.querySelectorAll<HTMLElement>(".svc-card");
  if (svcCards.length) {
    const obs = new IntersectionObserver(
      (entries) => entries.forEach((e) => {
        if (e.isIntersecting) { e.target.classList.add("visible"); obs.unobserve(e.target); }
      }),
      { threshold: 0.12 },
    );
    svcCards.forEach((c) => obs.observe(c));
  }

  /* ── WhatsApp button ── */
  const PHONE = "5551993975325";
  document.getElementById("main-schedule-btn")?.addEventListener("click", (e) => {
    e.preventDefault();
    window.open(
      `https://wa.me/${PHONE}?text=${encodeURIComponent("Olá! Gostaria de agendar uma sessão.")}`,
      "_blank", "noopener,noreferrer",
    );
  });

  /* ── 3D tilt on desktop cards ── */
  const MAX_TILT = 8;
  document.querySelectorAll<HTMLElement>(".svc-card").forEach((card) => {
    card.addEventListener("mousemove", (e: MouseEvent) => {
      const r  = card.getBoundingClientRect();
      const rx = ((e.clientY - r.top  - r.height / 2) / (r.height / 2)) * -MAX_TILT;
      const ry = ((e.clientX - r.left - r.width  / 2) / (r.width  / 2)) *  MAX_TILT;
      card.classList.remove("tilt-reset");
      card.style.transform  = `translateY(0) perspective(800px) rotateX(${rx}deg) rotateY(${ry}deg) scale(1.02)`;
      card.style.boxShadow  = `0 24px 60px rgba(0,0,0,0.14)`;
    });
    card.addEventListener("mouseleave", () => {
      card.classList.add("tilt-reset");
      card.style.transform = `translateY(0) perspective(800px) rotateX(0deg) rotateY(0deg) scale(1)`;
      card.style.boxShadow = "";
    });
  });
</script>
