---
const services = [
  {
    title: "Liberação Miofascial",
    image: "/liberacaoMiofascial.avif",
    description: "Técnica que atua nas fáscias musculares para restaurar mobilidade, aliviar tensões profundas e eliminar restrições de movimento.",
    tag: "Terapia Manual",
    imgPosition: "top"
  },
  {
    title: "Drenagem Linfática Manual",
    image: "/drenagemLinfatica.avif",
    description: "Estimula o sistema linfático para reduzir edemas, eliminar toxinas e melhorar a circulação em todo o organismo.",
    tag: "Bem-estar",
    imgPosition: "bottom"
  },
  {
    title: "Drenagem Pós-operatório",
    image: "/drenagemPosOperatorio.avif",
    description: "Protocolo especializado para acelerar a recuperação após cirurgias, reduzindo inchaço e auxiliando na cicatrização.",
    tag: "Recuperação",
    imgPosition: "top"
  },
  {
    title: "Massagem Relaxante",
    image: "/massagemRelaxante.avif",
    description: "Promove relaxamento profundo, alivia o estresse e restabelece o equilíbrio físico e mental com técnicas suaves e fluidas.",
    tag: "Massoterapia",
    imgPosition: "top"
  },
  {
    title: "Massagem Terapêutica",
    image: "https://biocap.com.br/wp-content/uploads/2023/11/foto_blog_Novembro_1024x641_01.png",
    description: "Foco no alívio de dores musculares e articulares, utilizando técnicas específicas para tratar tensões e pontos de tensão.",
    tag: "Massoterapia",
    imgPosition: "top"
  },
  {
    title: "Massagem Detox",
    image: "/massagemDetox.avif",
    description: "Estimula a eliminação de toxinas, melhora a circulação e proporciona sensação de leveza e renovação para o corpo.",
    tag: "Massoterapia",
    imgPosition: "bottom"
  },
  {
    title: "Auriculoterapia",
    image: "/auriculoterapia.avif",
    description: "Técnica baseada em pontos específicos da orelha para equilibrar o organismo, aliviar dores e reduzir o estresse.",
    tag: "Terapia Integrativa",
    imgPosition: "top"
  },
  {
    title: "Diagnóstico Postural",
    image: "/diagnosticoPostural.avif",
    description: "Avaliação completa da postura para identificar desequilíbrios e traçar um plano de intervenção personalizado.",
    tag: "Avaliação",
    imgPosition: "top"
  },
  {
    title: "Recovery",
    image: "/recovery.avif",
    description: "Protocolo de recuperação ativa para atletas e praticantes de atividade física, visando regeneração muscular e performance.",
    tag: "Performance",
    imgPosition: "top"
  },
  {
    title: "Exercícios Terapêuticos",
    image: "/exerciciosTerapeutico.avif",
    description: "Prescrição e acompanhamento de exercícios para melhora da dor, reorganização postural e qualidade de vida.",
    tag: "Saúde & Movimento",
