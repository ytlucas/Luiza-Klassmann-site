---
// Navbar component - uses inline script for mobile menu toggle
---

<nav
  id="navbar"
  class="fixed w-full z-50 transition-all duration-500 py-6 md:py-8 translate-y-0 px-4 md:px-6"
>
  <div id="nav-inner" class="max-w-7xl mx-auto px-6 flex justify-between items-center md:grid md:grid-cols-3 md:bg-[rgba(255,255,255,0.04)] md:backdrop-blur-[10px] md:border md:border-[rgba(255,255,255,0.08)] md:rounded-[22px] md:py-3 md:px-8 transition-all duration-300">
    <!-- Logo -->
    <a href="#inicio" class="group flex items-center md:justify-self-start">
      <img
        src="/logo.avif"
        alt="Luiza Klassmann Logo"
        class="h-10 md:h-12 w-auto"
      />
    </a>

    <!-- Desktop Menu -->
    <div class="hidden md:flex items-center justify-center space-x-8 lg:space-x-12">
      {
        [
          { name: "Início", href: "#inicio" },
          { name: "Sobre", href: "#sobre" },
          { name: "Serviços", href: "#servicos" },
          { name: "Cursos", href: "#cursos" },
          { name: "Contato", href: "#contato" },
        ].map((link) => (
          <a
            href={link.href}
            class="nav-link text-[11px] uppercase tracking-[0.2em] font-bold text-white hover:text-brand-terracotta transition-colors relative group"
          >
            {link.name}
            <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-brand-terracotta transition-all group-hover:w-full" />
          </a>
        ))
      }
    </div>

    <!-- Desktop CTA -->
    <div class="hidden md:flex justify-self-end">
      <a
        href="#contato"
        class="px-8 py-3 bg-brand-terracotta/90 hover:bg-brand-terracotta text-white rounded-full text-[11px] font-bold uppercase tracking-widest transition-all shadow-[0_4px_20px_rgba(193,122,98,0.3)] backdrop-blur-sm"
      >
        Agendar
      </a>
    </div>

    <!-- Mobile Toggle -->
    <button
      id="mobile-menu-btn"
      class="md:hidden text-brand-ink p-2"
      aria-label="Abrir menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg
        id="icon-menu"
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <line x1="3" y1="12" x2="21" y2="12"></line><line
          x1="3"
          y1="6"
          x2="21"
          y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
      <svg
        id="icon-close"
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
        class="hidden"
      >
        <line x1="18" y1="6" x2="6" y2="18"></line><line
          x1="6"
          y1="6"
          x2="18"
          y2="18"></line>
      </svg>
    </button>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="hidden absolute top-full left-0 w-full bg-white/95 backdrop-blur-2xl shadow-2xl overflow-hidden"
  >
    <div class="flex flex-col p-8 space-y-6">
      {
        [
          { name: "Início", href: "#inicio" },
          { name: "Sobre", href: "#sobre" },
          { name: "Serviços", href: "#servicos" },
          { name: "Cursos", href: "#cursos" },
          { name: "Contato", href: "#contato" },
        ].map((link) => (
          <a
            href={link.href}
            class="mobile-link text-xl font-serif text-brand-ink hover:text-brand-terracotta transition-colors"
          >
            {link.name}
          </a>
        ))
      }
    </div>
  </div>
</nav>

<script>
  const navbar = document.getElementById("navbar");
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  const iconMenu = document.getElementById("icon-menu");
  const iconClose = document.getElementById("icon-close");
  const mobileLinks = document.querySelectorAll(".mobile-link");

  // Scroll hide/show + background effect
  let lastY = window.scrollY;
  const navLinks = document.querySelectorAll<HTMLElement>(".nav-link");

  function updateLinkColors(scrolled: boolean) {
    navLinks.forEach((link) => {
      if (scrolled) {
        link.style.color = "#2D2A26"; // brand-ink
      } else {
        link.style.color = "#ffffff";
      }
    });
  }

  // Set initial state
  updateLinkColors(window.scrollY > 50);

  window.addEventListener(
    "scroll",
    () => {
      const currentY = window.scrollY;
      const scrollingDown = currentY > lastY;
      const scrolled = currentY > 50;

      if (scrolled) {
        navbar?.classList.add("py-3");
        navbar?.classList.remove("py-6", "md:py-8");
        const navInner = document.getElementById("nav-inner");
        navInner?.classList.add("bg-white/90", "backdrop-blur-xl", "shadow-lg", "md:border-transparent");
        navInner?.classList.remove("md:bg-[rgba(255,255,255,0.04)]", "md:backdrop-blur-[10px]", "md:border-[rgba(255,255,255,0.08)]");
      } else {
        navbar?.classList.remove("py-3");
        navbar?.classList.add("py-6", "md:py-8");
        const navInner = document.getElementById("nav-inner");
        navInner?.classList.remove("bg-white/90", "backdrop-blur-xl", "shadow-lg", "md:border-transparent");
        navInner?.classList.add("md:bg-[rgba(255,255,255,0.04)]", "md:backdrop-blur-[10px]", "md:border-[rgba(255,255,255,0.08)]");
      }

      updateLinkColors(scrolled);

      // Hide on scroll down, reveal on scroll up
      if (scrollingDown && currentY > 120) {
        navbar?.classList.add("-translate-y-full");
        navbar?.classList.remove("translate-y-0");
      } else {
        navbar?.classList.remove("-translate-y-full");
        navbar?.classList.add("translate-y-0");
      }

      lastY = currentY;
    },
    { passive: true },
  );

  // Mobile toggle
  btn?.addEventListener("click", () => {
    const isOpen = !menu?.classList.contains("hidden");
    menu?.classList.toggle("hidden", isOpen);
    iconMenu?.classList.toggle("hidden", !isOpen);
    iconClose?.classList.toggle("hidden", isOpen);
    btn?.setAttribute("aria-expanded", String(!isOpen));
    btn?.setAttribute("aria-label", !isOpen ? "Fechar menu" : "Abrir menu");
  });

  // Close on link click
  mobileLinks.forEach((link) => {
    link.addEventListener("click", () => {
      menu?.classList.add("hidden");
      iconMenu?.classList.remove("hidden");
      iconClose?.classList.add("hidden");
    });
  });
</script>
