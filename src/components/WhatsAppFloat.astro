---
// Floating WhatsApp button with pulse animation
// Phone: +55 51 99397-5325 → wa.me/5551993975325
---
<a
  href="https://wa.me/5551993975325"
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Fale conosco pelo WhatsApp"
  class="whatsapp-float fixed bottom-10 right-10 w-20 h-20 bg-[#25D366] text-white rounded-[24px] flex items-center justify-center z-50 group"
>
  <!-- Pulse ring -->
  <span class="absolute inset-0 rounded-[24px] bg-[#25D366] pulse-ring"></span>

  <!-- Icon with bounce -->
  <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="relative z-10 group-hover:scale-110 transition-transform duration-300 icon-bounce">
    <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
  </svg>
</a>

<style>
  /* Pop-in on load */
  .whatsapp-float {
    animation: popIn 0.5s 1s ease-out both;
    box-shadow: 0 20px 50px rgba(37, 211, 102, 0.4);
    transition: box-shadow 0.3s, transform 0.3s;
  }
  .whatsapp-float:hover {
    box-shadow: 0 20px 60px rgba(37, 211, 102, 0.6);
    transform: scale(1.1);
  }
  .whatsapp-float:active {
    transform: scale(0.95);
  }

  @keyframes popIn {
    from { opacity: 0; transform: scale(0) rotate(-45deg); }
    to   { opacity: 1; transform: scale(1) rotate(0deg); }
  }

  /* Gentle continuous pulse ring */
  .pulse-ring {
    animation: pulseRing 2.5s ease-out infinite;
    opacity: 0;
  }
  @keyframes pulseRing {
    0%   { transform: scale(1);   opacity: 0.6; }
    80%  { transform: scale(1.55); opacity: 0; }
    100% { transform: scale(1.55); opacity: 0; }
  }

  /* Subtle idle bounce on the icon */
  .icon-bounce {
    animation: idleBounce 3s ease-in-out infinite;
  }
  @keyframes idleBounce {
    0%, 100% { transform: translateY(0); }
    40%      { transform: translateY(-4px); }
    60%      { transform: translateY(-2px); }
  }
</style>
