---
// About section – Luiza is also a mentor
---

<section
  id="sobre"
  class="pb-12 pt-0 md:pb-20 md:pt-0 bg-white relative overflow-hidden"
>
  <div
    class="max-w-7xl mx-auto px-6 grid lg:grid-cols-2 gap-10 md:gap-16 items-center"
  >
    <!-- Image -->
    <div class="relative reveal">
      <div
        class="rounded-[60px] overflow-hidden shadow-2xl aspect-square relative z-10"
      >
        <img
          src="/fotoProfissional2.avif"
          alt="Luiza Klassmann - Massoterapeuta e Mentora em Porto Alegre"
          class="w-full h-full object-cover"
          loading="lazy"
        />
      </div>
      <div
        class="absolute -bottom-10 -right-10 w-64 h-64 bg-brand-sage/10 rounded-full -z-10 blur-3xl"
      >
      </div>
      <div
        class="absolute -top-10 -left-10 w-48 h-48 bg-brand-terracotta/10 rounded-full -z-10 blur-2xl"
      >
      </div>
    </div>

    <!-- Text -->
    <div class="reveal">
      <h2 class="text-5xl md:text-6xl mb-10 leading-tight">
        Uma trajetória dedicada à <span
          class="text-brand-terracotta italic font-light">saúde</span
        > e ao bem-estar.
      </h2>
      <div
        class="space-y-8 text-brand-ink/70 leading-relaxed font-light text-lg"
      >
        <p class="mb-4">
          Sou <strong class="font-bold text-gray-900">Luiza C. Klassmann</strong
          >, profissional de <strong class="font-bold">Educação Física</strong> há
          15 anos e <strong class="font-bold">Massoterapeuta</strong> há quase uma
          década. Pós-graduada em Saúde Coletiva e Acupuntura em andamento, atualmente
          divido minha rotina em lecionar no curso de Massoterapia, mentorias individuais
          e atendimentos clínicos.
        </p>

        <p class="mb-4">
          Minha atuação considera o aspecto integral do SER, respeitando
          individualidades, e utiliza como ferramenta a <strong
            class="font-bold">Terapia Manual e o movimento corporal</strong
          > para alcançar uma vida funcional e com qualidade.
        </p>

        <p>
          <strong class="font-bold"
            >Liberação Miofascial, Drenagem Linfática, Diagnóstico Postural,
            Auriculoterapia, Ventosaterapia e massagens</strong
          > são técnicas que fazem parte dos meus atendimentos, bem como discussão
          e orientação de Treinamento Físico.
        </p>
        <div class="grid grid-cols-2 gap-6 pt-8">
          <!-- Autoridade -->
          <div
            class="about-feat-card relative rounded-2xl p-5 border border-brand-terracotta/10 bg-brand-terracotta/5 space-y-3"
            style="--snake-color: #C17A62;"
          >
            <div class="snake-border"></div>
            <div
              class="w-10 h-10 bg-brand-terracotta/10 rounded-xl flex items-center justify-center text-brand-terracotta"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><circle cx="12" cy="8" r="6"></circle><path
                  d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"></path></svg
              >
            </div>
            <h4 class="font-bold text-xs uppercase tracking-widest">
              Autoridade
            </h4>
            <p class="text-sm text-brand-ink/50">
              Referência no ensino de terapias manuais.
            </p>
          </div>

          <!-- Mentora -->
          <div
            class="about-feat-card relative rounded-2xl p-5 border border-brand-sage/10 bg-brand-sage/5 space-y-3"
            style="--snake-color: #8A9A79;"
          >
            <div class="snake-border"></div>
            <div
              class="w-10 h-10 bg-brand-sage/10 rounded-xl flex items-center justify-center text-brand-sage"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"
                ></path><path d="M19 10v2a7 7 0 0 1-14 0v-2"></path><line
                  x1="12"
                  x2="12"
                  y1="19"
                  y2="22"></line></svg
              >
            </div>
            <h4 class="font-bold text-xs uppercase tracking-widest">Mentora</h4>
            <p class="text-sm text-brand-ink/50">
              Formando profissionais de excelência.
            </p>
          </div>

          <!-- Performance -->
          <div
            class="about-feat-card relative rounded-2xl p-5 border border-brand-gold/10 bg-brand-gold/5 space-y-3"
            style="--snake-color: #C5A059;"
          >
            <div class="snake-border"></div>
            <div
              class="w-10 h-10 bg-brand-gold/10 rounded-xl flex items-center justify-center text-brand-gold"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"
                ></polygon></svg
              >
            </div>
            <h4 class="font-bold text-xs uppercase tracking-widest">
              Performance
            </h4>
            <p class="text-sm text-brand-ink/50">
              Foco em resultados reais e duradouros.
            </p>
          </div>

          <!-- Cuidado -->
          <div
            class="about-feat-card relative rounded-2xl p-5 border border-brand-terracotta/10 bg-brand-terracotta/5 space-y-3"
            style="--snake-color: #C17A62;"
          >
            <div class="snake-border"></div>
            <div
              class="w-10 h-10 bg-brand-terracotta/10 rounded-xl flex items-center justify-center text-brand-terracotta"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path
                  d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"
                ></path></svg
              >
            </div>
            <h4 class="font-bold text-xs uppercase tracking-widest">Cuidado</h4>
            <p class="text-sm text-brand-ink/50">
              Atendimento humanizado e personalizado.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .snake-border {
    position: absolute;
    inset: -1px;
    border-radius: inherit;
    padding: 1.5px;
    -webkit-mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
    overflow: hidden;
  }
  .snake-border::before {
    content: "";
    position: absolute;
    top: 50%;
    left: 50%;
    width: 250%;
    height: 250%;
    background: conic-gradient(
      from 0deg,
      transparent 70%,
      var(--snake-color) 100%
    );
    transform: translate(-50%, -50%);
    animation: spin-snake 4s linear infinite;
  }
  @keyframes spin-snake {
    0% {
      transform: translate(-50%, -50%) rotate(0deg);
    }
    100% {
      transform: translate(-50%, -50%) rotate(360deg);
    }
  }
  .reveal {
    opacity: 0;
    transform: translateY(30px);
    transition:
      opacity 0.7s ease,
      transform 0.7s ease;
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .about-feat-card {
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease,
      border-color 0.3s ease,
      background-color 0.3s ease;
    cursor: default;
  }
  .about-feat-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.08);
    border-color: rgba(193, 122, 98, 0.3);
    background-color: rgba(193, 122, 98, 0.1);
  }
  .about-feat-card:hover .w-10 {
    transform: scale(1.15);
    transition: transform 0.3s ease;
  }
  @media (min-width: 1024px) {
    .about-feat-card h4 {
      font-size: 1rem !important;
      line-height: 1.1;
    }
  }
</style>
<script>
  const reveals = document.querySelectorAll(".reveal");
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) entry.target.classList.add("visible");
      });
    },
    { threshold: 0.15 },
  );
  reveals.forEach((el) => observer.observe(el));
</script>
