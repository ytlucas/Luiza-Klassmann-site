---
// Before & After / Resultados section
const results = [
  { src: "/resultado1.avif", alt: "Resultado antes e depois 1" },
  { src: "/resultado2.avif", alt: "Resultado antes e depois 2" },
];
---
<section id="resultados" class="py-12 md:py-20 bg-[#FDFBF7] overflow-hidden">
  <div class="max-w-7xl mx-auto px-6">
    <!-- Header -->
    <div class="result-reveal text-center mb-14">
      <span class="text-brand-terracotta text-[10px] font-bold uppercase tracking-[0.4em] mb-4 block">
        Transformações Reais
      </span>
      <h2 class="text-5xl md:text-6xl mb-4 leading-[1.1]">
        Antes &amp; <span class="text-brand-terracotta italic font-light">Depois</span>
      </h2>
      <p class="text-brand-ink/60 text-xl max-w-2xl mx-auto font-light leading-relaxed">
        Veja os resultados reais alcançados por nossas clientes com os tratamentos de Luiza Klassmann.
      </p>
    </div>

    <!-- Results grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 max-w-2xl mx-auto">
      {results.map((r, i) => (
        <div
          class="result-card group relative overflow-hidden rounded-3xl shadow-lg"
          style={`--delay: ${i * 100}ms`}
        >
          <div class="w-full h-96 bg-[#f5f5f5] flex items-center justify-center">
            <img
              src={r.src}
              alt={r.alt}
              class="max-w-full max-h-full object-contain"
              loading="lazy"
            />
          </div>
          <!-- Subtle gradient overlay -->
          <div class="absolute inset-0 bg-gradient-to-t from-brand-ink/50 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          <!-- hover label -->
          <div class="absolute bottom-4 left-1/2 -translate-x-1/2 bg-white/90 backdrop-blur-sm text-brand-ink text-xs font-bold uppercase tracking-widest px-5 py-2 rounded-full opacity-0 group-hover:opacity-100 translate-y-2 group-hover:translate-y-0 transition-all duration-400 whitespace-nowrap">
            Resultado #{i + 1}
          </div>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="result-reveal text-center mt-14">
      <a
        href="#contato"
        class="inline-block px-12 py-5 bg-brand-terracotta text-white rounded-full font-bold text-sm tracking-widest uppercase hover:bg-brand-ink transition-all shadow-xl shadow-brand-terracotta/20"
      >
        Quero esses resultados
      </a>
    </div>
  </div>
</section>

<style>
  .result-reveal {
    opacity: 0;
    transform: translateY(32px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }
  .result-reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Card 1 slides in from the left, card 2 from the right */
  .result-card {
    opacity: 0;
    transition: opacity 0.7s ease var(--delay, 0ms), transform 0.7s ease var(--delay, 0ms), box-shadow 0.4s;
  }
  .result-card:nth-child(odd)  { transform: translateX(-60px) scale(0.95); }
  .result-card:nth-child(even) { transform: translateX( 60px) scale(0.95); }
  .result-card.visible {
    opacity: 1;
    transform: translateX(0) scale(1);
  }
  .result-card:hover {
    transform: translateY(-6px) scale(1.02);
    box-shadow: 0 28px 56px rgba(0,0,0,0.15);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
</style>
<script>
  const reveals = document.querySelectorAll('.result-reveal');
  const revObs = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.15 });
  reveals.forEach(e => revObs.observe(e));

  const cards = document.querySelectorAll('.result-card');
  const cardObs = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.1 });
  cards.forEach(c => cardObs.observe(c));
</script>
